<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper"
    tools:context=".MainActivity" >

    <TextView
        android:id="@+id/textView"
        android:layout_width="429dp"
        android:layout_height="78dp"
        android:layout_marginTop="214dp"
        android:layout_marginBottom="1071dp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:text="Counter"
        android:textAlignment="center"
        android:textColor="#1D9E22"
        android:textColorLink="#9DA92A"
        android:textSize="48sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="394dp"
        android:layout_height="139dp"
        android:gravity="right"
        android:text="0"
        android:textColor="#F1EFEBEB"
        android:textSize="100sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="485dp" />

    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <androidx.constraintlayout.widget.Barrier android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/button2"
        android:layout_width="202dp"
        android:layout_height="178dp"
        android:backgroundTint="#46474C"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="755dp"
        tools:visibility="invisible" />

    <Button
        android:id="@+id/button3"
        android:layout_width="241dp"
        android:layout_height="233dp"
        android:text="33"
        android:textSize="55sp"
        app:layout_constraintBottom_toBottomOf="@+id/button4"
        app:layout_constraintTop_toTopOf="@+id/button4"
        tools:layout_editor_absoluteX="53dp" />

    <Button
        android:id="@+id/button4"
        android:layout_width="241dp"
        android:layout_height="233dp"
        android:text="100"
        android:textSize="55sp"
        tools:layout_editor_absoluteX="483dp"
        tools:layout_editor_absoluteY="1066dp" />

    <Button
        android:id="@+id/button5"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:text="Reset"
        android:textSize="15sp"
        tools:layout_editor_absoluteX="483dp"
        tools:layout_editor_absoluteY="679dp"
        tools:visibility="visible" />

    <androidx.constraintlayout.widget.Barrier android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</androidx.constraintlayout.widget.ConstraintLayout>